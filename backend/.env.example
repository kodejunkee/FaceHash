# Server Configuration
PORT=5000

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# AES-256 Encryption Configuration
# Generate a 32-byte (256-bit) hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_ENCRYPTION_KEY=your-64-character-hex-key-here

# Similarity threshold for face matching (lower = stricter)
FACE_MATCH_THRESHOLD=0.6
